<h2>Available Jobs</h2>

<p>Here are some jobs:</p>

<ul>
  <% if (jobs.length === 0) { %>
    <p>No jobs available right now.</p>
  <% } else { %>
    <% jobs.forEach(job => { %>
      <li>
        <strong><%= job.title %></strong><br>
        <%= job.description %><br>
        ₹<%= job.amount %> / <%= job.wage_type %>
        <hr>
      </li>
    <% }) %>
  <% } %>
</ul>